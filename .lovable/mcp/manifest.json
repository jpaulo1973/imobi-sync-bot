{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://flinkqnbowsdjdeexsaq.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "imomatch-mcp",
      "version": "0.1.0",
      "title": "ImoMatch"
    },
    "tools": [
      {
        "name": "list_properties",
        "title": "List properties",
        "description": "List the signed-in user's imported properties (imóveis) in ImoMatch. Returns basic fields like reference, typology, zone, price, area.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max rows to return (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            },
            "finalidade": {
              "description": "Filter by purpose: venda or arrendamento.",
              "type": "string",
              "enum": [
                "venda",
                "arrendamento"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_buyer_clients",
        "title": "List buyer clients",
        "description": "List the signed-in user's buyer leads (compradores) in ImoMatch, optionally filtered to active ones.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max rows to return (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            },
            "only_active": {
              "description": "If true, only ativo=true rows.",
              "type": "boolean"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_portal_listings",
        "title": "List portal listings",
        "description": "List the signed-in user's imported portal listings (anúncios de portais como Idealista, Imovirtual, Casa Sapo).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max rows to return (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
